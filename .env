# ─── Copy this file to .env and fill in your values ───────────────────────────

# ── GROQ API (FREE) ──────────────────────────────────────────────────────────
# Get your FREE key at: https://console.groq.com  (no credit card needed)
GROQ_API_KEY=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

# Free Groq models — pick one:
#   llama-3.1-8b-instant    ← fastest (recommended for demos)
#   llama-3.3-70b-versatile ← smarter answers, still free
#   mixtral-8x7b-32768      ← great for longer documents
#   gemma2-9b-it            ← Google's lightweight model
LLM_MODEL=llama-3.1-8b-instant

# ── Embedding model (local, no API key needed) ────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB persistence directory ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Chunking parameters ───────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=4
CONFIDENCE_THRESHOLD=0.55

# ── HITL ──────────────────────────────────────────────────────────────────────
HITL_QUEUE_DIR=./hitl_queue

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
